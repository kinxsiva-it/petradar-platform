generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  REPORTER
  PET_OWNER
  VOLUNTEER
  ADMIN
}

enum AccountStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum VolunteerVerificationState {
  NOT_APPLICABLE
  PENDING
  VERIFIED
  REJECTED
}

enum AnimalSpecies {
  CAT
  DOG
  OTHER
}

enum AnimalCondition {
  NORMAL_STRAY
  INJURED
  NEEDS_RESCUE
  NEWBORN_LITTER
  POSSIBLE_LOST_PET
  SICK
  PREGNANT
  AGGRESSIVE
  UNKNOWN
}

enum CollarStatus {
  NO_COLLAR
  RED_COLLAR_WITH_BELL
  BLUE_COLLAR
  UNKNOWN
  OTHER
}

enum UrgencyLevel {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum SightingLifecycleStatus {
  SIGHTING
  POSSIBLE_MATCH
  NEEDS_RESCUE
  REUNITED
  CLOSED
}

enum VerificationStatus {
  PENDING
  VERIFIED
  COMMUNITY_VERIFIED
  NEEDS_REVIEW
  REJECTED
  DUPLICATE
}

enum PhotoStorageProvider {
  EXTERNAL_URL
  SUPABASE
  LOCAL_PLACEHOLDER
}

enum LostPetStatus {
  LOST
  POSSIBLE_MATCH
  REUNITED
  CLOSED
}

enum LostPetSex {
  UNKNOWN
  FEMALE
  MALE
}

enum MatchLevel {
  LOW
  MEDIUM
  HIGH
}

enum MatchReviewStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum RescueCaseStatus {
  NEW_REPORT
  NEEDS_VERIFICATION
  NEEDS_RESCUE
  ASSIGNED
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum RescueSeverity {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum RescueTimelineEventType {
  CREATED
  STATUS_CHANGED
  VOLUNTEER_ASSIGNED
  NOTE_ADDED
}

enum NotificationType {
  SIGHTING_VERIFIED
  SIGHTING_REJECTED
  MATCH_FOUND
  MATCH_CONFIRMED
  MATCH_REJECTED
  RESCUE_ASSIGNED
  RESCUE_STATUS_UPDATED
}

model User {
  id                    String                     @id @default(uuid()) @db.Uuid
  email                 String                     @unique
  displayName           String
  passwordHash          String                     @map("password_hash")
  phone                 String?
  roles                 UserRole[]                 @default([REPORTER])
  status                AccountStatus              @default(ACTIVE)
  volunteerVerification VolunteerVerificationState @default(NOT_APPLICABLE) @map("volunteer_verification")
  createdAt             DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)

  refreshTokens        RefreshToken[]
  sightings            AnimalSighting[]
  auditLogs            AuditLog[]
  lostPets             LostPet[]                 @relation("LostPetOwner")
  reviewedMatches      MatchResult[]             @relation("MatchReviewer")
  assignedRescueCases  RescueCase[]              @relation("AssignedRescueVolunteer")
  createdRescueCases   RescueCase[]              @relation("CreatedRescueCase")
  rescueTimelineEvents RescueCaseTimelineEvent[]
  internalNotes        RescueInternalNote[]
  notifications        Notification[]

  @@index([status])
  @@index([volunteerVerification])
  @@map("users")
}

model Notification {
  id           String           @id @default(uuid()) @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  type         NotificationType
  title        String           @db.VarChar(160)
  message      String           @db.VarChar(500)
  actionUrl    String?          @map("action_url") @db.VarChar(500)
  resourceType String?          @map("resource_type") @db.VarChar(80)
  resourceId   String?          @map("resource_id") @db.Uuid
  metadata     Json?
  readAt       DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@index([userId, type])
  @@unique([userId, type, resourceType, resourceId])
  @@map("notifications")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash")
  userAgent         String?   @map("user_agent")
  ipHash            String?   @map("ip_hash")
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  replacedByToken RefreshToken?  @relation("RefreshTokenRotation", fields: [replacedByTokenId], references: [id])
  replacesTokens  RefreshToken[] @relation("RefreshTokenRotation")

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AnimalSighting {
  id                    String                               @id @default(uuid()) @db.Uuid
  reporterId            String?                              @map("reporter_id") @db.Uuid
  species               AnimalSpecies
  animalCount           Int                                  @default(1) @map("animal_count")
  color                 String?
  pattern               String?
  collarStatus          CollarStatus                         @default(UNKNOWN) @map("collar_status")
  condition             AnimalCondition                      @default(UNKNOWN)
  description           String?
  seenAt                DateTime                             @map("seen_at") @db.Timestamptz(6)
  urgency               UrgencyLevel                         @default(LOW)
  lifecycleStatus       SightingLifecycleStatus              @default(SIGHTING) @map("lifecycle_status")
  verificationStatus    VerificationStatus                   @default(PENDING) @map("verification_status")
  exactLocation         Unsupported("geography(Point,4326)") @map("exact_location")
  publicLocation        Unsupported("geography(Point,4326)") @map("public_location")
  publicRadiusMeters    Int                                  @map("public_radius_meters")
  duplicateOfSightingId String?                              @map("duplicate_of_sighting_id") @db.Uuid
  createdAt             DateTime                             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime                             @updatedAt @map("updated_at") @db.Timestamptz(6)

  reporter            User?            @relation(fields: [reporterId], references: [id], onDelete: SetNull)
  photos              SightingPhoto[]
  matchResults        MatchResult[]
  rescueCases         RescueCase[]
  duplicateOfSighting AnimalSighting?  @relation("SightingDuplicateMerge", fields: [duplicateOfSightingId], references: [id], onDelete: SetNull)
  duplicateSightings  AnimalSighting[] @relation("SightingDuplicateMerge")

  @@index([reporterId])
  @@index([duplicateOfSightingId])
  @@index([species])
  @@index([lifecycleStatus])
  @@index([verificationStatus])
  @@index([urgency])
  @@index([seenAt])
  @@index([createdAt])
  @@map("animal_sightings")
}

model SightingPhoto {
  id              String               @id @default(uuid()) @db.Uuid
  sightingId      String               @map("sighting_id") @db.Uuid
  storageProvider PhotoStorageProvider @default(EXTERNAL_URL) @map("storage_provider")
  storageKey      String?              @map("storage_key")
  url             String
  mimeType        String?              @map("mime_type")
  fileSizeBytes   Int?                 @map("file_size_bytes")
  sortOrder       Int                  @default(0) @map("sort_order")
  createdAt       DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  sighting AnimalSighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)

  @@index([sightingId, sortOrder])
  @@map("sighting_photos")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  requestId  String?  @map("request_id")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model LostPet {
  id                     String                               @id @default(uuid()) @db.Uuid
  ownerId                String                               @map("owner_id") @db.Uuid
  name                   String
  species                AnimalSpecies
  breed                  String?
  sex                    LostPetSex                           @default(UNKNOWN)
  age                    String?
  color                  String?
  pattern                String?
  collarDescription      String?                              @map("collar_description")
  microchipped           Boolean                              @default(false)
  description            String?
  photoUrls              String[]                             @default([]) @map("photo_urls")
  exactLastSeenLocation  Unsupported("geography(Point,4326)") @map("exact_last_seen_location")
  publicLastSeenLocation Unsupported("geography(Point,4326)") @map("public_last_seen_location")
  publicRadiusMeters     Int                                  @map("public_radius_meters")
  lastSeenAt             DateTime                             @map("last_seen_at") @db.Timestamptz(6)
  contactMethod          String?                              @map("contact_method")
  rewardCents            Int?                                 @map("reward_cents")
  status                 LostPetStatus                        @default(LOST)
  createdAt              DateTime                             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime                             @updatedAt @map("updated_at") @db.Timestamptz(6)

  owner        User          @relation("LostPetOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  matchResults MatchResult[]

  @@index([ownerId])
  @@index([species])
  @@index([status])
  @@index([lastSeenAt])
  @@index([createdAt])
  @@map("lost_pets")
}

model MatchResult {
  id              String            @id @default(uuid()) @db.Uuid
  lostPetId       String            @map("lost_pet_id") @db.Uuid
  sightingId      String            @map("sighting_id") @db.Uuid
  score           Int
  level           MatchLevel
  reviewStatus    MatchReviewStatus @default(PENDING) @map("review_status")
  reasons         Json
  distanceMeters  Float?            @map("distance_meters")
  matchedAt       DateTime          @default(now()) @map("matched_at") @db.Timestamptz(6)
  reviewerId      String?           @map("reviewer_id") @db.Uuid
  reviewedAt      DateTime?         @map("reviewed_at") @db.Timestamptz(6)
  rejectionReason String?           @map("rejection_reason")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  lostPet  LostPet        @relation(fields: [lostPetId], references: [id], onDelete: Cascade)
  sighting AnimalSighting @relation(fields: [sightingId], references: [id], onDelete: Cascade)
  reviewer User?          @relation("MatchReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@unique([lostPetId, sightingId])
  @@index([lostPetId])
  @@index([sightingId])
  @@index([reviewStatus])
  @@index([level])
  @@index([matchedAt])
  @@map("match_results")
}

model RescueCase {
  id                  String           @id @default(uuid()) @db.Uuid
  caseNumber          String           @unique @map("case_number")
  sightingId          String           @map("sighting_id") @db.Uuid
  severity            RescueSeverity
  status              RescueCaseStatus @default(NEW_REPORT)
  summary             String
  assignedVolunteerId String?          @map("assigned_volunteer_id") @db.Uuid
  createdById         String?          @map("created_by_id") @db.Uuid
  closedAt            DateTime?        @map("closed_at") @db.Timestamptz(6)
  createdAt           DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  sighting          AnimalSighting            @relation(fields: [sightingId], references: [id], onDelete: Restrict)
  assignedVolunteer User?                     @relation("AssignedRescueVolunteer", fields: [assignedVolunteerId], references: [id], onDelete: SetNull)
  createdBy         User?                     @relation("CreatedRescueCase", fields: [createdById], references: [id], onDelete: SetNull)
  timelineEvents    RescueCaseTimelineEvent[]
  internalNotes     RescueInternalNote[]

  @@index([status])
  @@index([severity])
  @@index([sightingId])
  @@index([assignedVolunteerId])
  @@index([createdAt])
  @@map("rescue_cases")
}

model RescueCaseTimelineEvent {
  id             String                  @id @default(uuid()) @db.Uuid
  rescueCaseId   String                  @map("rescue_case_id") @db.Uuid
  eventType      RescueTimelineEventType @map("event_type")
  previousStatus RescueCaseStatus?       @map("previous_status")
  newStatus      RescueCaseStatus?       @map("new_status")
  actorId        String?                 @map("actor_id") @db.Uuid
  note           String?
  metadata       Json?
  createdAt      DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)

  rescueCase RescueCase @relation(fields: [rescueCaseId], references: [id], onDelete: Cascade)
  actor      User?      @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([rescueCaseId, createdAt])
  @@index([actorId])
  @@map("rescue_case_timeline_events")
}

model RescueInternalNote {
  id           String   @id @default(uuid()) @db.Uuid
  rescueCaseId String   @map("rescue_case_id") @db.Uuid
  authorId     String?  @map("author_id") @db.Uuid
  body         String
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  rescueCase RescueCase @relation(fields: [rescueCaseId], references: [id], onDelete: Cascade)
  author     User?      @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([rescueCaseId, createdAt])
  @@index([authorId])
  @@map("rescue_internal_notes")
}
