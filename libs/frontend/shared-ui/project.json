{
  "name": "frontend-shared-ui",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/frontend/shared-ui/src",
  "projectType": "library",
  "tags": ["scope:frontend", "type:ui"],
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/web/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --no-error-on-unmatched-pattern libs/frontend/shared-ui/**/*.ts libs/frontend/shared-ui/**/*.html"
      }
    }
  }
}
