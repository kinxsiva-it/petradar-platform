{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "declaration": false,
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "outDir": "../../dist/out-tsc/web",
    "rootDir": "../..",
    "types": []
  },
  "angularCompilerOptions": {
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": ["src/main.ts"],
  "include": ["src/**/*.ts", "../../libs/frontend/**/*.ts"],
  "exclude": [
    "src/**/*.spec.ts",
    "src/app/ui-prototype.pages.ts",
    "src/app/mock-data/**/*.ts",
    "../../libs/frontend/**/*.spec.ts"
  ]
}
