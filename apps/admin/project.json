{
  "name": "admin",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/admin/src",
  "projectType": "application",
  "tags": ["scope:frontend", "type:app", "area:admin"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng serve admin --host 127.0.0.1 --port 4201"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "ng build admin"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/admin/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --no-error-on-unmatched-pattern apps/admin/**/*.ts apps/admin/**/*.html libs/frontend/admin/**/*.ts libs/frontend/admin/**/*.html"
      }
    }
  }
}
